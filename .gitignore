# =========================================
# NEVER COMMIT — personal financial data
# =========================================
# Keep memory/ as a directory but ignore everything in it except .gitkeep
memory/
!memory/.gitkeep

# Anything that looks like real data
transactions_*.json
accounts_*.json
balances_*.json
holdings_*.json
*.csv
debug/
raw_*.json
*-personal.md
*-private.md

# Browser data / sessions
.chrome-profile/
user-data-dir/
*.cookies
playwright/.auth/

# Credentials of any kind
.env
.env.*
!.env.example
secrets.json
credentials.json
*.pem
*.key
*.p12
*.pfx

# Logs (may contain account numbers, balances)
*.log
logs/

# Personal Claude settings (may contain paths / tokens)
.claude/settings.local.json
.claude/settings.json
!.claude/settings.example.json

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# Node (in case anyone adds JS tooling later)
node_modules/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
